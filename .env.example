# Copy this file to `.env` and fill values (never commit `.env`).
#
# Supabase: Dashboard → Project Settings → API
# - Project URL  → VITE_SUPABASE_URL
# - anon public  → VITE_SUPABASE_ANON_KEY (long JWT starting with eyJ...)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional: extra master-admin emails (comma-separated). Built-in defaults include
# master@trading.com and usmchayward@yahoo.com.
# VITE_MASTER_ADMIN_EMAILS=

# Optional (only if your build reads these from Vite)
VITE_FINNHUB_API_KEY=

# Tradier market data → Edge Function `tradier-proxy` secrets (Supabase Dashboard → Edge Functions → Secrets):
#   TRADIER_API_KEY, TRADIER_ACCOUNT_ID, TRADIER_USE_SANDBOX=true
# CLI: supabase secrets set --project-ref YOUR_REF TRADIER_API_KEY=... TRADIER_ACCOUNT_ID=... TRADIER_USE_SANDBOX=true
